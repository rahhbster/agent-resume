{
  "name": "@agent-resume/schemas",
  "version": "1.0.0",
  "description": "Canonical JSON Schemas + TypeScript types for AI-native hiring: CCDM (candidate), JD-CDM (job), MatchObject, and HMAC-signed SyncEvent webhooks.",
  "license": "MIT",
  "author": "agent-resume contributors",
  "homepage": "https://agent-resume.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rahhbster/agent-resume.git",
    "directory": "packages/schemas"
  },
  "bugs": {
    "url": "https://github.com/rahhbster/agent-resume/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./schemas/ccdm": "./src/schemas/ccdm.v1.json",
    "./schemas/jdcdm": "./src/schemas/jdcdm.v1.json",
    "./schemas/match-object": "./src/schemas/match-object.v1.json",
    "./schemas/sync-event": "./src/schemas/sync-event.v1.json"
  },
  "files": [
    "dist",
    "src/schemas"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "check:dialect": "node scripts/check-dialect-migration.mjs",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "resume",
    "ats",
    "hiring",
    "recruiting",
    "json-schema",
    "candidate",
    "job-description",
    "ai",
    "llm",
    "agent",
    "matching",
    "jsonresume",
    "ccdm",
    "jd-cdm",
    "webhook",
    "hmac"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "ajv": "^8.16.0",
    "ajv-formats": "^3.0.1"
  }
}
